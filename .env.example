MPESA_CONSUMER_SECRET=EYk0O76ZnHoayoge9EGIRKGQtAvUZiG8uHG7mZwd5J5h0QZNs44IOLnTR27CzPhi

# M-Pesa Shortcode (Sandbox default is 174379)
