MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# PayBill Configuration (Your actual PayBill)
MPESA_PAYBILL=222111
MPESA_ACCOUNT=2571412

# Callback URL (Your Vercel domain + /api/mpesa-callback)
# Example: https://vfd-shop.vercel.app/api/mpesa-callback
MPESA_CALLBACK_URL=https://your-domain.vercel.app/api/mpesa-callback

# C2B URLs
C2B_VALIDATION_URL=https://your-domain.vercel.app/api/c2b-validation
C2B_CONFIRMATION_URL=https://your-domain.vercel.app/api/c2b-confirmation

# ==========================================
# Supabase Configuration
# ==========================================

# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==========================================
# Application Configuration
# ==========================================

# Site URL (Your Vercel deployment URL)
NEXT_PUBLIC_SITE_URL=https://v-f-d.github.io

# API Base URL (for API routes)
API_BASE_URL=https://your-domain.vercel.app

# ==========================================
# Email Configuration (Optional - for order notifications)
# ==========================================

# EmailJS (already set up on frontend)
EMAIL_SERVICE_ID=your_service_id
EMAIL_TEMPLATE_ID=your_template_id
EMAIL_PUBLIC_KEY=1Yy9BmUn8aid2j5Rs

# ==========================================
# Security
# ==========================================

# API Secret (for securing internal API calls)
API_SECRET=your-random-secret-key-here

# ==========================================
# NOTES FOR DEPLOYMENT:
# ==========================================

# 1. VERCEL SETUP:
#    - Create account at vercel.com
#    - Import this GitHub repository
#    - Add all environment variables in Vercel dashboard
#    - Deploy!

# 2. M-PESA PRODUCTION:
#    - Go Live on Daraja portal
#    - Replace sandbox credentials with production credentials
#    - Update MPESA_CALLBACK_URL with your production URL
#    - Register C2B URLs via Daraja API

# 3. SUPABASE SETUP:
#    - Create account at supabase.com
#    - Create new project
#    - Run the SQL schema (see SUPABASE_SCHEMA.md)
#    - Get API keys from project settings
#    - Add to environment variables

# 4. TESTING:
#    - Use Safaricom test numbers: 254708374149, 254722000000
#    - Test amounts: 1, 10, 100, 1000
#    - Check callbacks in Vercel logs
