				},
				"url": {
					"raw": "https://vfd-shop.vercel.app/api/mpesa-stk-push",
					"protocol": "https",
					"host": ["vfd-shop", "vercel", "app"],
					"path": ["api", "mpesa-stk-push"]
				}
			},
			"response": []
