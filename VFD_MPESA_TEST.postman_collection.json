						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"BusinessShortCode\": \"174379\",\n    \"Password\": \"{{password}}\",\n    \"Timestamp\": \"{{timestamp}}\",\n    \"TransactionType\": \"CustomerPayBillOnline\",\n    \"Amount\": \"1\",\n    \"PartyA\": \"254706036754\",\n    \"PartyB\": \"174379\",\n    \"PhoneNumber\": \"254706036754\",\n    \"CallBackURL\": \"https://vfd-shop.vercel.app/api/mpesa-callback\",\n    \"AccountReference\": \"VFD-TEST-001\",\n    \"TransactionDesc\": \"Test Payment VFD Shop\"\n}"
				},
				"url": {
					"raw": "https://sandbox.safaricom.co.ke/mpesa/stkpush/v1/processrequest",
					"protocol": "https",
					"host": ["sandbox", "safaricom", "co", "ke"],
					"path": ["mpesa", "stkpush", "v1", "processrequest"]
				}
			},
			"response": []
		},
