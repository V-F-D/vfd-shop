{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/shop",
      "dest": "/shop.html"
    },
    {
      "src": "/gallery",
      "dest": "/gallery.html"
    },
    {
      "src": "/course_outline",
      "dest": "/course_outline.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
